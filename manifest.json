{
  "manifest_version": 3,
  "name": "lawCYpen",
  "version": "0.2.0",
  "description": "Authorized-scope HTTP traffic capture, history, and Repeater — a Burp-style companion built into DevTools.",
  "permissions": ["storage", "scripting", "tabs"],
  "host_permissions": ["https://dns.google/*", "https://s3.amazonaws.com/*"],
  "optional_host_permissions": ["https://*/*", "http://*/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "lawCYpen"
  },
  "devtools_page": "devtools/devtools.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
